# Environment Variables for Quantum Mail Backend
# Copy this file to .env and update with your actual values

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DB_USERNAME=postgres
DB_PASSWORD=sakthivel
DB_NAME=blockmail
DB_PORT=5432

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
APP_PORT=8080

# ==========================================
# SECURITY CONFIGURATION
# ==========================================
# IMPORTANT: Generate a strong secret key for production
# You can generate one using: openssl rand -base64 32
JWT_SECRET_KEY=sakthivelcms
JWT_EXPIRATION=86400000

# ==========================================
# EMAIL CONFIGURATION
# ==========================================
# Gmail SMTP Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=sakthiveldkodi@gmail.com
MAIL_PASSWORD=yjzagbpzxlmnepev

# For other email providers:
# Outlook: smtp-mail.outlook.com:587
# Yahoo: smtp.mail.yahoo.com:587
# Custom SMTP: your-smtp-server.com:587

# ==========================================
# QKD CONFIGURATION
# ==========================================
# Set to 'true' for development/testing, 'false' for production
QKD_MOCK_MODE=true
QKD_BASE_URL=http://localhost:8080/api/v1/keys
QKD_KEY_SIZE=256
QKD_POOL_SIZE=10
QKD_LIFETIME=3600

# ==========================================
# CORS CONFIGURATION
# ==========================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://localhost:5175

# Production example:
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ==========================================
# NOTES
# ==========================================
# 1. Never commit the .env file to version control
# 2. Always use strong passwords in production
# 3. Use environment-specific .env files (.env.dev, .env.prod)
# 4. For Gmail, use App Passwords: https://support.google.com/accounts/answer/185833
# 5. Rotate JWT secret keys periodically

